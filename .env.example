# OpenAI API настройки для эмбеддингов (Модуль 4)
# Скопируйте этот файл в .env и заполните свои значения

# API ключ OpenAI (обязательно для векторизации)
# Получите ключ на https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Базовый URL API (опционально, для прокси)
# Используйте прокси, если у вас нет прямого доступа к OpenAI API
OPENAI_API_BASE=https://openai.api.proxyapi.ru/v1

# Модель эмбеддингов (опционально)
# По умолчанию: text-embedding-3-small
# Другие варианты: text-embedding-3-large, text-embedding-ada-002
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Язык OCR (опционально)
# По умолчанию: rus+eng
# Поддерживаемые языки: rus, eng, deu, fra, spa и др.
OCR_LANG=rus+eng

# Размер чанка по умолчанию (опционально)
# По умолчанию: 500
DEFAULT_CHUNK_SIZE=500

# Перекрытие между чанками (опционально)
# По умолчанию: 50
DEFAULT_OVERLAP=50

# Уровень логирования (опционально)
# Возможные значения: DEBUG, INFO, WARNING, ERROR, CRITICAL
# По умолчанию: INFO
LOG_LEVEL=INFO

# Язык интерфейса (опционально)
# Возможные значения: ru, en
# По умолчанию: ru
LANGUAGE=ru
